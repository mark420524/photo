<view class="">
        <view class="custom-size-photo">
            
            <view class="container">
                <view class="image-wrap">
                    <view class="height-control" style="{{lineHeight}}" >
                        <label class="_span">{{height}}</label>
                    </view>
                    <view class="imageWrap" style="{{imageWrapStyle}}" >
                        <image alt="true" bindload="imageOnLoad" class="_image image" style="{{imageStyle}}" mode="widthFix" src="https://c01.parameters.cn/image/fw8mR5KEDQQUimnX.png" 
                       
                         ></image>
                    </view>
                    <view class="width-control" style="{{lineWidth}}" >
                        <label class="_span">{{width}}</label>
                    </view>
                </view>
            </view>
            <view class="_section form">
                <van-tabs bindchange="_pe" class="_van-tabs" color="#1989fa" data-cid="{{_c||c}}" data-hid="{{18}}" value="{{h[18].value}}">
                    <van-tab class="_van-tab" title="{{h[ 19+'-'+(unit_i2!==undefined?unit_i2:index) ].title}}" wx:for="{{h[19].li}}" wx:for-item="unit" wx:key="index"></van-tab>
                </van-tabs>
                <view class="form-item-wrap">
                    <view class="form-item-input">
                        <view class="custom-input">
                            <input bindinput="_pe" class="_input" data-cid="{{_c||c}}" data-hid="{{24}}" max="200" min="10" placeholder="{{h[24].placeholder}}" type="number" value="{{h[24].value}}"></input>
                            <label class="_span">{{h[27].t}}</label>
                        </view>
                        <label class="_label">宽度</label>
                    </view>
                    <view class="symbol">X</view>
                    <view class="form-item-input">
                        <view class="custom-input">
                            <input bindinput="_pe" class="_input" data-cid="{{_c||c}}" data-hid="{{37}}" max="200" min="10" placeholder="{{h[37].placeholder}}" type="number" value="{{h[37].value}}"></input>
                            <label class="_span">{{h[40].t}}</label>
                        </view>
                        <label class="_label">高度</label>
                    </view>
                </view>
                <van-button bindtap="_pe" class="_van-button" data-cid="{{_c||c}}" data-hid="{{45}}" disabled="{{h[45].disabled}}" size="large" type="primary">下一步
        </van-button>
            </view>
        </view>
    </view>